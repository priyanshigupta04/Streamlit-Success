# backend/.env.example — copy to .env and fill in values
PORT=5000
MONGODB_URI=mongodb://localhost:27017/streamlining_success
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
AI_SERVICE_URL=http://localhost:8000
NODE_ENV=development

# ====================================
# CLOUDINARY CONFIGURATION (For Document Storage)
# ====================================
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ====================================
# INSTITUTION DETAILS (For NOC & Document Templates)
# ====================================
INSTITUTION_NAME=Your College/University Name
INSTITUTION_ADDRESS=Address, City, State - PIN
INSTITUTION_PHONE=+91-XXXX-XXXXXX
INSTITUTION_EMAIL=contact@institution.edu

# ====================================
# OPTIONAL: Email Configuration
# ====================================
# (For future email dispatch feature)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SENDER_EMAIL=noreply@institution.edu
