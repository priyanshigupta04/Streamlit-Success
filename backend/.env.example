# backend/.env.example — copy to .env and fill in values
PORT=5000
MONGO_URI=mongodb://localhost:27017/streamlining_success
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_URLS=http://localhost:8000
AI_HEALTH_TIMEOUT_MS=15000
AI_REQUEST_TIMEOUT_MS=25000
AI_MAX_RETRIES=2
AI_RETRY_BASE_DELAY_MS=1500
AI_WAKEUP_ON_RETRY=true
NODE_ENV=development

# ====================================
# JOB LIFECYCLE CLEANUP (Deadline Based)
# ====================================
# Auto-close expired jobs and auto-delete after grace period.
AUTO_JOB_CLEANUP_ENABLED=true
JOB_CLEANUP_INTERVAL_MINUTES=60
JOB_DELETE_GRACE_DAYS=4

# ====================================
# SYSTEM MANAGED: Placement Cell Account
# ====================================
# This account is auto-created/updated at backend startup.
PLACEMENT_CELL_NAME=Placement Cell
PLACEMENT_CELL_EMAIL=placementcell@institution.edu
PLACEMENT_CELL_PASSWORD=Placement@123

# ====================================
# CLOUDINARY CONFIGURATION (For Document Storage)
# ====================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ====================================
# INSTITUTION DETAILS (For NOC & Document Templates)
# ====================================
INSTITUTION_NAME=Your College/University Name
INSTITUTION_ADDRESS=Address, City, State - PIN
INSTITUTION_PHONE=+91-XXXX-XXXXXX
INSTITUTION_EMAIL=contact@institution.edu

# ====================================
# OPTIONAL: Email Configuration
# ====================================
# (For future email dispatch feature)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SENDER_EMAIL=noreply@institution.edu
